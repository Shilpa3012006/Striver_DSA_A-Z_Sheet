
class Solution:
    def NthRoot(self, n, m):
        ans=1
        low=1
        high=m
        # eps=1e-6
        while low<=high:
            mid=(low+high)//2
            if mid**n<=m:
                ans=mid
                low=mid+1
            else:
                high=mid-1

        if type(ans)==int:
            return ans
        else:
            return -1
      
