class Solution:
    def maxLen(self, arr):
        # Your code goes here
        prefix_sum=0
        max_len=0
        prefix_map={0:-1}
        for i in range(len(arr)):
            prefix_sum+=arr[i]
            if prefix_sum in prefix_map:
                length=i-prefix_map[prefix_sum]
                max_len=max(max_len,length)
            if prefix_sum not in prefix_map:
                prefix_map[prefix_sum]=i
        return max_len
            
