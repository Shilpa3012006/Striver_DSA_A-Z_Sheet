#to print the nth row of pascal Triangle using row number

#brute force approch T.C O(n^2) S.C O(1)
n=int(input())
def ncr(row,col):
    res=1
    for i in range(col):
        res=res*(row-i)
        res=res//(i+1)
    return int(res)

for i in range(1,n+1):
    print(ncr(n-1,i-1),end=" ")

#optimised approch T.C O(n) S.C O(1)
ans=1
print(ans,end=" ")
for i in range(1,n):
    ans=ans*(n-i)
    ans=ans//i
    print(ans,end=" ")
