#optimal approch T.C O(n) S.C O(1)
price=list(map(int,input().split()))
n=len(price)
max_profit=0
mini_price=price[0]
for i in range(1,n):
    profit=price[i]-mini_price
    max_profit=max(max_profit,profit)
    mini_price=min(mini_price,price[i])
print(max_profit)


#brute force approch T.C O(n^2) S.C O(n)

for i in range(n):
    for j in range(i+1,n):
        profit=price[j]-price[i]
        if profit>0:
            max_profit=max(max_profit,profit)
print(max_profit)
