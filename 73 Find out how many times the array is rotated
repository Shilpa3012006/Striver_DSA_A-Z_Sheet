nums = list(map(int, input().split()))
n = len(nums)
low=0
high=n-1
ans=float('inf')
index=-1
while low<=high:
    mid=(low+high)//2

    # if left half is sorted
    if nums[low]<=nums[mid]:
        # ans=min(ans,nums[low])
        if nums[low]<ans:
            index=low
            ans=nums[low]
        low=mid+1
    else:
        # ans=min(ans,nums[mid])
        if nums[mid]<ans:
            index=mid
            ans=nums[mid]
        high=mid-1
print(index)
