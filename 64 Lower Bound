class Solution:
    def lowerBound(self, nums, x):
        n = len(nums)
        low=0
        high=n-1
        while low<=high:
            mid=(low+high)//2
            if nums[mid]==x:
                return mid
            elif nums[mid]<x and (mid==n-1 or nums[mid+1]>x):
                return mid+1
            elif nums[mid]<x:
                low=mid+1
            else:
                high=mid-1
       


